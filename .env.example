# Copy this file to .env.local and fill in the values.

# NextAuth
# `openssl rand -base64 32` to generate
NEXTAUTH_SECRET=replace-me
NEXTAUTH_URL=http://localhost:3000

# Google OAuth 2.0 credentials
# https://console.cloud.google.com/apis/credentials
# Make sure the OAuth consent screen has the Calendar readonly scope added.
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Google Gemini API key
# https://aistudio.google.com/app/apikey
GOOGLE_GEMINI_API_KEY=your-gemini-api-key

# Optional: override the Gemini model. Defaults to gemini-2.5-flash.
# Use this if Google deprecates the default and you need to swap quickly.
# GEMINI_MODEL=gemini-2.5-flash
