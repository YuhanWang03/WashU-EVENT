# Copy this file to .env.local and fill in the values.

# NextAuth
# `openssl rand -base64 32` to generate
NEXTAUTH_SECRET=replace-me
NEXTAUTH_URL=http://localhost:3000

# Google OAuth 2.0 credentials
# https://console.cloud.google.com/apis/credentials
# Make sure the OAuth consent screen has the Calendar readonly scope added.
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# DeepSeek API key (OpenAI-compatible)
# https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=your-deepseek-api-key

# Optional: override the DeepSeek base URL. Defaults to https://api.deepseek.com.
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# Optional: override the DeepSeek model. Defaults to deepseek-chat.
# DEEPSEEK_MODEL=deepseek-chat

# ── Docker Compose (read from .env by `docker compose`) ───────────────────
# Token the mock Canvas server accepts (see mock_canvas/).
MOCK_CANVAS_TOKEN=mock-token-dev
# Where the backend reaches Canvas. Defaults to the in-compose mock; point at
# a real Canvas host (e.g. https://canvas.instructure.com) to use live data.
CANVAS_BASE_URL=http://mock_canvas:8080
CANVAS_ACCESS_TOKEN=mock-token-dev
